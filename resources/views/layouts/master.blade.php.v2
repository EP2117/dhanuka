            transform: translateX(5px);
        }

        .collapse-item.active {
            background: var(--gray-lighter) !important;
            color: var(--gray-darkest) !important;
            font-weight: 600;
        }

        /* =========================================================
            SIDEBAR DIVIDER
           ========================================================= */

        .sidebar-divider {
            border-color: rgba(255, 255, 255, 0.15) !important;
        }

        /* =========================================================
            LOGO STYLING
           ========================================================= */

        .sidebar-brand-icon img {
            border-radius: 12px;
            box-shadow: 0 4px 14px var(--shadow-md);
            border: 2px solid var(--gray-light);
        }

        /* Logout text */
        .side-log {
            color: var(--gray-lighter) !important;
        }

        /* =========================================================
            PRIMARY TEXT OVERRIDE (Bootstrap)
           ========================================================= */

        /* Make all .text-primary elements use dark gray */
        .text-primary {
            color: var(--gray-darkest) !important;
        }

        /* Hover state (links, etc.) */
        .text-primary:hover,
        a.text-primary:hover {
            color: var(--gray-medium) !important;
        }

        /* =========================================================
            BREADCRUMB GRAY THEME
           ========================================================= */

        /* breadcrumb text color */
        .breadcrumb,
        .breadcrumb-item,
        .breadcrumb-item a {
            color: var(--gray-medium) !important;
            font-weight: 500;
        }

        /* breadcrumb divider ( / or > ) */
        .breadcrumb-item+.breadcrumb-item::before {
            color: var(--gray-light) !important;
            font-weight: 600;
        }

        /* active breadcrumb item */
        .breadcrumb-item.active {
            color: var(--gray-darkest) !important;
            font-weight: 600;
        }

        /* breadcrumb hover */
        .breadcrumb-item a:hover {
            color: var(--gray-darkest) !important;
            text-decoration: underline;
        }

        /* =========================================================
            ADDITIONAL ENHANCEMENTS
           ========================================================= */

        /* Form Controls */
        .form-control:focus,
        .form-select:focus {
            border-color: var(--gray-medium);
            box-shadow: 0 0 0 0.2rem rgba(93, 109, 126, 0.25);
        }

        .form-control,
        .form-select {
            border-color: var(--gray-lightest);
        }

        .form-control:hover,
        .form-select:hover {
            border-color: var(--gray-lighter);
        }

        /* Cards */
        .card {
            border-color: var(--gray-lightest);
            box-shadow: 0 2px 8px var(--shadow-sm);
        }

        .card-header {
            background: linear-gradient(135deg, var(--gray-bg) 0%, #ffffff 100%);
            border-bottom: 2px solid var(--gray-lighter);
            color: var(--gray-darkest);
            font-weight: 600;
        }

        /* Tables */
        .table thead th {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%);
            color: #ffffff;
            font-weight: 600;
        }

        .table-hover tbody tr:hover {
            background-color: var(--gray-bg) !important;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: var(--gray-50);
        }

        /* Alerts */
        .alert-primary {
            background-color: var(--gray-bg);
            border-color: var(--gray-lighter);
            color: var(--gray-darkest);
        }

        /* Dropdown Menus */
        .dropdown-menu {
            border-radius: 12px;
            box-shadow: 0 10px 25px var(--shadow-lg);
            border: 1px solid var(--gray-lightest);
        }

        .dropdown-item {
            color: var(--gray-darkest);
            transition: all 0.2s ease;
        }

        .dropdown-item:hover {
            background-color: var(--gray-bg);
            color: var(--gray-darkest);
        }

        .dropdown-item i {
            color: var(--gray-medium);
        }

        /* Links */
        a {
            color: var(--gray-medium);
            transition: all 0.2s ease;
        }

        a:hover {
            color: var(--gray-darkest);
        }

        /* Footer */
        .sticky-footer {
            background: #ffffff !important;
            border-top: 1px solid var(--gray-lightest);
            box-shadow: 0 -2px 10px var(--shadow-sm);
        }

        .sticky-footer .copyright {
