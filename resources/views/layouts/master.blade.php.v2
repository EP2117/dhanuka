        }

        .sticky-footer .copyright strong {
            color: var(--gray-darkest);
        }

        /* Scroll to Top Button */
        .scroll-to-top {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%) !important;
            border: 2px solid var(--gray-light);
            box-shadow: 0 4px 12px var(--shadow-md);
        }

        .scroll-to-top:hover {
            background: linear-gradient(135deg, var(--gray-dark) 0%, var(--gray-medium) 100%) !important;
            transform: translateY(-2px);
        }

        /* Input Groups */
        .input-group-text {
            background-color: var(--gray-bg);
            border-color: var(--gray-lightest);
            color: var(--gray-medium);
        }

        /* List Groups */
        .list-group-item.active {
            background-color: var(--gray-darkest);
            border-color: var(--gray-darkest);
        }

        .list-group-item:hover {
            background-color: var(--gray-50);
        }

        /* Modals */
        .modal-header {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%);
            color: white;
        }

        .modal-header .btn-close {
            filter: invert(1);
        }

        /* Tabs */
        .nav-tabs .nav-link.active {
            background-color: white;
            border-color: var(--gray-lightest) var(--gray-lightest) white;
            color: var(--gray-darkest);
            font-weight: 600;
        }

        .nav-tabs .nav-link:hover {
            border-color: var(--gray-lighter);
            color: var(--gray-medium);
        }

        /* =========================================================
            RESPONSIVE ADJUSTMENTS
           ========================================================= */

        @media (max-width: 768px) {
            .topbar::after {
