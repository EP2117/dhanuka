        /* Active */
        .sidebar .nav-link.active {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0.1) 100%) !important;
            border-left: 4px solid var(--gray-light) !important;
