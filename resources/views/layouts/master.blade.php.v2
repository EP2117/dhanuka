        }

        /* Hover */
        .sidebar .nav-link:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #fff !important;
            transform: translateX(5px);
        }

        .sidebar .nav-link:hover i {
            color: var(--white) !important;
