        }

        /* Gray accent line at bottom of topbar */
        .topbar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--gray-medium) 0%, var(--gray-light) 50%, var(--gray-medium) 100%);
        }

        .topbar a,
        .topbar .nav-link,
        .topbar .navbar-brand,
