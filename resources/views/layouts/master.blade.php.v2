    <script>
        // kamlesh Start
        // Remove mouseover/mouseleave auto-expand behaviour.
        // Keep mobile toggle click showing logo safely (guarded).
        const mobileView = document.querySelector('#sidebarToggleTop');
        if (mobileView) {
            mobileView.addEventListener('click', function() {
                const logoEl = document.querySelector('#logo');
                if (logoEl) {
                    logoEl.style.display = "inline";
                }
            });
        }

        // Previously we had 'mouseleave' and 'mouseover' listeners on .sidebar.
        // Those have been removed so sidebar will not auto-expand/collapse on hover.
        // Sidebar now controlled only by collapse/toggle buttons or explicit JS.

        // If you have code elsewhere that depends on sidebar mouse handlers, update it to call
        // your toggle functions instead (e.g., click handlers or keyboard shortcuts).

        // kamlesh end

        $(document).ready(function() {
            const timeout = 1800000; // 900000 ms = 15 minutes 1800000 ms = 30 minutes
            var idleTimer = null;
            $('*').bind(
                'mousemove click mouseup mousedown keydown keypress keyup submit change mouseenter scroll resize dblclick',
                function() {
                    clearTimeout(idleTimer);

                    idleTimer = setTimeout(function() {
                        document.getElementById('logout-form').submit();
                    }, timeout);
                });
            $("body").trigger("mousemove");

            $(document).on('keypress', 'body .num_txt', function(evt) {

                evt = (evt) ? evt : window.event;
                var charCode = (evt.which) ? evt.which : evt.keyCode;

                if ((charCode > 31 && (charCode < 48 || charCode > 57)) && charCode !== 46) {
                    evt.preventDefault();;
                } else {
                    return true;
                }

                /*if ((charCode > 31 && (charCode < 48 || charCode > 57)) && charCode !== 46) {
                evt.preventDefault();;
                }*/
            });

            $(".sidebar").on('click', function(evt) {
                console.log(evt.target);
                //if(evt.target.className != 'collapse-item' && !(evt.target.className.includes('inventory'))) {
                $('.collapse').collapse('hide');
                //}
            });

            $(document).on('keypress', 'body .decimal_no', function(evt) {
                var $this = $(this);
                if ((event.which != 46 || $this.val().indexOf('.') != -1) &&
                    ((event.which < 48 || event.which > 57) &&
                        (event.which != 0 && event.which != 8))) {
                    event.preventDefault();
                }

                var text = $(this).val();
                if ((event.which == 46) && (text.indexOf('.') == -1)) {
                    setTimeout(function() {
                        if ($this.val().substring($this.val().indexOf('.')).length > 3) {
                            $this.val($this.val().substring(0, $this.val().indexOf('.') + 3));
                        }
                    }, 1);
                }

                if ((text.indexOf('.') != -1) &&
                    (text.substring(text.indexOf('.')).length > 2) &&
                    (event.which != 0 && event.which != 8) &&
                    ($(this)[0].selectionStart >= text.length - 2)) {
                    event.preventDefault();
                }
            });

            $('.decimal_no').bind("paste", function(e) {
                var text = e.originalEvent.clipboardData.getData('Text');
                if ($.isNumeric(text)) {
                    if ((text.substring(text.indexOf('.')).length > 3) && (text.indexOf('.') > -1)) {
                        e.preventDefault();
                        $(this).val(text.substring(0, text.indexOf('.') + 3));
                    }
                } else {
                    e.preventDefault();
                }
            });

        });
    </script>
</body>

</html>
