    <style>
        /* =========================================================
            LIGHT GRAY, DARK GRAY & WHITE THEME (Bootstrap overrides)
           ========================================================= */

        /* Grayscale color palette */
        :root {
            /* Gray Scale Palette */
            --gray-darkest: #2C3E50;
            --gray-dark: #34495E;
            --gray-medium: #5D6D7E;
            --gray-light: #85929E;
            --gray-lighter: #AEB6BF;
            --gray-lightest: #D5DBDB;
            --gray-bg: #ECF0F1;
            --gray-bg-light: #F8F9FA;
            --gray-50: #FAFBFC;

            /* White */
            --white: #FFFFFF;

            /* Bootstrap Variable Overrides */
            --bs-primary: #2C3E50 !important;
            --bs-primary-rgb: 44, 62, 80 !important;
            --bs-primary-bg: #2C3E50 !important;
            --bs-primary-border: #2C3E50 !important;
            --bs-link-color: #5D6D7E !important;
            --bs-link-hover-color: #2C3E50 !important;

            /* Shadows */
            --shadow-sm: rgba(44, 62, 80, 0.08);
            --shadow-md: rgba(44, 62, 80, 0.15);
            --shadow-lg: rgba(44, 62, 80, 0.25);
        }

        /* =========================================================
            BUTTONS
           ========================================================= */

        .btn-primary {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%) !important;
            border-color: var(--gray-darkest) !important;
            color: #ffffff !important;
            font-weight: 600;
            box-shadow: 0 2px 8px var(--shadow-md);
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, var(--gray-dark) 0%, var(--gray-medium) 100%) !important;
            border-color: var(--gray-dark) !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px var(--shadow-md);
        }

        .btn-primary:active,
        .btn-primary:focus {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, #1a252f 100%) !important;
            border-color: var(--gray-darkest) !important;
            box-shadow: 0 0 0 0.2rem rgba(44, 62, 80, 0.5);
        }

        /* =========================================================
            BADGES
           ========================================================= */

        .bg-primary,
        .badge-primary {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%) !important;
            color: #ffffff !important;
        }

        /* =========================================================
            PAGINATION
           ========================================================= */

        .page-item.active .page-link {
            background-color: var(--gray-darkest) !important;
            border-color: var(--gray-darkest) !important;
            color: #ffffff !important;
            font-weight: 600;
        }

        .page-link {
            color: var(--gray-medium) !important;
            border-color: var(--gray-lightest) !important;
        }

        .page-link:hover {
            background-color: var(--gray-bg) !important;
            border-color: var(--gray-lighter) !important;
            color: var(--gray-darkest) !important;
        }

        .page-link:focus {
            box-shadow: 0 0 0 0.2rem rgba(44, 62, 80, 0.25);
        }

        /* =========================================================
