    <style>
        :root {
            /* Gray Scale Palette */
            --gray-darkest: #2C3E50;
            --gray-dark: #34495E;
            --gray-medium: #5D6D7E;
            --gray-light: #85929E;
            --gray-lighter: #AEB6BF;
            --gray-lightest: #D5DBDB;
            --gray-bg: #ECF0F1;
            --gray-bg-light: #F8F9FA;
            --gray-50: #FAFBFC;
            --gray-100: #F4F5F7;
            
            /* White */
            --white: #FFFFFF;
            
            /* Functional Colors */
            --shadow-sm: rgba(44, 62, 80, 0.08);
            --shadow-md: rgba(44, 62, 80, 0.15);
            --shadow-lg: rgba(44, 62, 80, 0.25);
            --border-color: rgba(44, 62, 80, 0.1);
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--gray-50);
            margin: 0;
            padding: 0;
        }

        /* Modern Navbar */
        .navbar {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%) !important;
            box-shadow: 0 4px 6px -1px var(--shadow-md), 0 2px 4px -1px var(--shadow-sm);
            border: none;
            margin-bottom: 2rem !important;
            position: relative;
        }

        .navbar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--gray-medium) 0%, var(--gray-light) 50%, var(--gray-medium) 100%);
        }

        #logo {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            margin-right: 15px;
            box-shadow: 0 4px 6px var(--shadow-md);
            border: 2px solid var(--gray-light);
        }

        .navbar h3 {
            color: white !important;
            font-family: 'Merriweather', serif;
            font-weight: 700;
            margin: 0;
            font-size: 24px;
            text-shadow: 0 2px 4px var(--shadow-sm);
        }

        /* User Dropdown */
        .nav-link {
            color: white !important;
            transition: all 0.3s ease;
            border-radius: 10px;
            padding: 8px 16px !important;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.15);
        }

        .nav-link span {
            color: white !important;
            font-weight: 500;
        }

        .dropdown-menu {
            border-radius: 12px;
            box-shadow: 0 10px 25px var(--shadow-lg);
            border: 1px solid var(--gray-lightest);
            padding: 8px;
            background: var(--white);
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 10px 16px;
            transition: all 0.2s ease;
            color: var(--gray-darkest);
            font-weight: 500;
        }

        .dropdown-item:hover {
            background: var(--gray-100);
            color: var(--gray-dark);
        }

        .dropdown-item i {
            color: var(--gray-medium);
            margin-right: 8px;
        }

        /* Container */
        .container-fluid {
            padding: 0 2rem 2rem 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Card Grid - Compatible with Bootstrap */
        .home-main {
            display: flex;
            flex-wrap: wrap;
            margin: 0 -12px;
        }

        .home-main>div {
            padding: 0 12px;
            margin-bottom: 24px;
            width: 33.333%;
            flex: 0 0 33.333%;
        }

        /* Modern Cards */
        .carhover {
            background: var(--white);
            border-radius: 16px;
            box-shadow: 0 1px 3px 0 var(--shadow-sm), 0 1px 2px 0 var(--shadow-sm);
            transition: all 0.3s ease;
            overflow: hidden;
            border: 1px solid var(--gray-lightest);
            height: 100%;
            position: relative;
        }

        .carhover::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--gray-medium) 0%, var(--gray-light) 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .carhover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px var(--shadow-md);
            border-color: var(--gray-light);
        }

        .carhover:hover::before {
            opacity: 1;
        }

        .carhover a {
            text-decoration: none;
            color: inherit;
            display: block;
            height: 100%;
        }

        .main-col {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 24px;
            min-height: 160px;
        }

        .col1-1 {
            flex: 1;
            padding-right: 16px;
        }

        .col1-1 h3 {
            font-size: 22px;
            font-weight: 700;
            color: var(--gray-darkest);
            margin: 0 0 14px 0;
            line-height: 1.2;
        }

        .col1-1 ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .col1-1 ul li {
            padding: 6px 0;
            color: var(--gray-light);
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            line-height: 1.4;
        }

        .col1-1 ul li i {
            margin-right: 8px;
            color: var(--gray-medium);
            font-size: 14px;
            width: 18px;
            flex-shrink: 0;
        }

        .col1-2 {
            width: 64px;
            height: 64px;
            min-width: 64px;
            min-height: 64px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--gray-dark) 100%);
            box-shadow: 0 4px 6px var(--shadow-md);
            flex-shrink: 0;
            border: 2px solid var(--gray-light);
        }

        .col1-2 i {
            font-size: 28px;
            color: white;
        }

        /* Card Color Variations with Gray Scale Theme */
        .card-1 .col1-2 {
            background: linear-gradient(135deg, var(--gray-dark) 0%, var(--gray-darkest) 100%);
            box-shadow: 0 4px 6px var(--shadow-md);
            border-color: var(--gray-lighter);
        }

        .card-2 .col1-2 {
            background: linear-gradient(135deg, var(--gray-medium) 0%, var(--gray-dark) 100%);
            box-shadow: 0 4px 6px var(--shadow-md);
            border-color: var(--gray-light);
        }

        .card-3 .col1-2 {
            background: linear-gradient(135deg, var(--gray-light) 0%, var(--gray-medium) 100%);
            box-shadow: 0 4px 6px var(--shadow-sm);
            border-color: var(--gray-lighter);
        }

        .card-4 .col1-2 {
            background: linear-gradient(135deg, var(--gray-darkest) 0%, #1a252f 100%);
            box-shadow: 0 4px 6px var(--shadow-md);
            border-color: var(--gray-medium);
        }

        .card-5 .col1-2 {
            background: linear-gradient(135deg, #5A6C7D 0%, var(--gray-medium) 100%);
            box-shadow: 0 4px 6px var(--shadow-md);
            border-color: var(--gray-light);
        }

        .card-6 .col1-2 {
            background: linear-gradient(135deg, var(--gray-dark) 0%, var(--gray-medium) 100%);
            box-shadow: 0 4px 6px var(--shadow-md);
            border-color: var(--gray-lighter);
        }

        /* Footer - Static, not fixed or sticky */
        .footer-wrapper {
            background: var(--white);
            border-top: 1px solid var(--gray-lightest);
            padding: 1.5rem 0;
            margin-top: 3rem;
            box-shadow: 0 -2px 10px var(--shadow-sm);
        }

        .footer-wrapper .copyright {
            color: var(--gray-medium);
            font-size: 14px;
            text-align: center;
            font-weight: 500;
        }

        .footer-wrapper .copyright strong {
            color: var(--gray-darkest);
        }

        /* Content Wrapper */
        #content-wrapper {
            display: block;
        }

        #content {
            display: block;
        }

        /* Tablet Responsive */
        @media (max-width: 1024px) {
            .home-main>div {
                width: 50%;
                flex: 0 0 50%;
            }

            .col1-1 h3 {
                font-size: 20px;
            }

            .main-col {
                padding: 20px;
                min-height: 150px;
            }
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .navbar {
                padding: 0.75rem 1rem;
            }

            .navbar h3 {
                font-size: 18px;
            }

            #logo {
                width: 40px;
                height: 40px;
                margin-right: 10px;
            }

            .container-fluid {
                padding: 0 1rem 1rem 1rem;
            }

            .home-main {
                margin: 0 -8px;
            }

            .home-main>div {
                width: 100%;
                flex: 0 0 100%;
                padding: 0 8px;
                margin-bottom: 16px;
            }

            .main-col {
                padding: 20px;
                min-height: 140px;
            }

            .col1-1 {
                padding-right: 12px;
            }

            .col1-1 h3 {
                font-size: 20px;
                margin-bottom: 12px;
            }

            .col1-1 ul li {
                font-size: 13px;
                padding: 5px 0;
            }

            .col1-1 ul li i {
                font-size: 13px;
                width: 16px;
            }

            .col1-2 {
                width: 56px;
                height: 56px;
                min-width: 56px;
                min-height: 56px;
            }

            .col1-2 i {
                font-size: 24px;
            }

            .nav-link span {
                font-size: 14px;
            }

            .footer-wrapper {
                margin-top: 2rem;
            }
        }

        /* Small Mobile */
        @media (max-width: 480px) {
            .navbar h3 {
                font-size: 16px;
            }

            .col1-1 h3 {
                font-size: 18px;
            }

            .main-col {
                padding: 16px;
            }
        }

        /* Smooth Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .carhover {
            animation: fadeIn 0.5s ease-out;
        }

        .home-main>div:nth-child(1) .carhover { animation-delay: 0.1s; }
        .home-main>div:nth-child(2) .carhover { animation-delay: 0.2s; }
        .home-main>div:nth-child(3) .carhover { animation-delay: 0.3s; }
        .home-main>div:nth-child(4) .carhover { animation-delay: 0.4s; }
        .home-main>div:nth-child(5) .carhover { animation-delay: 0.5s; }
        .home-main>div:nth-child(6) .carhover { animation-delay: 0.6s; }
    </style>
</head>

